{
  "name": "edas-assignmnet",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "tsx src/server.ts",
    "migration:run": "tsx ./node_modules/typeorm/cli.js migration:run -d src/config/database.ts",
    "migration:revert": "tsx ./node_modules/typeorm/cli.js migration:revert -d src/config/database.ts",
    "migration:generate": "tsx ./node_modules/typeorm/cli.js migration:generate -d src/config/database.ts",
    "migration:create": "tsx ./node_modules/typeorm/cli.js migration:create",
    "dev": "npm run migration:run && tsx src/server.ts",
    "build": "tsc",
    "typeorm": "tsx ./node_modules/typeorm/cli.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/abhishekdhadwal/edas-assignmnet.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/abhishekdhadwal/edas-assignmnet/issues"
  },
  "homepage": "https://github.com/abhishekdhadwal/edas-assignmnet#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-basic-auth": "^1.2.1",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^5.12.1",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.28",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
